{
  "manifest_version": 3,
  "name": "WA Privacy Blur",
  "version": "1.2",
  "description": "Blurs WhatsApp Web content for privacy — hover to reveal.",
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png",
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://web.whatsapp.com/*"],
      "js": ["blur.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://web.whatsapp.com/*"
  ]
}
